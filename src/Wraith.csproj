<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <RootNamespace>Wraith</RootNamespace>
    <AssemblyName>Wraith</AssemblyName>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <Version>2.1.1</Version>
    <Company>Wraith Security</Company>
    <Product>Wraith</Product>
    <Description>Real-time process surveillance and threat detection for Windows</Description>
    <NoWarn>CA1416</NoWarn>
    <ApplicationIcon>Assets\logo.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Diagnostics.Tracing.TraceEvent" Version="3.1.16" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\logo.jpg" />
  </ItemGroup>

</Project>

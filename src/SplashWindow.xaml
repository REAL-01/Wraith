<Window x:Class="Wraith.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="640"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>

        <Storyboard x:Key="SplashIn">
            <DoubleAnimation Storyboard.TargetName="ScaleMain"
                            Storyboard.TargetProperty="ScaleX"
                            From="0.3" To="1" Duration="0:0:0.6"
                            EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetName="ScaleMain"
                            Storyboard.TargetProperty="ScaleY"
                            From="0.3" To="1" Duration="0:0:0.6"
                            EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetName="MainGrid"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <Storyboard x:Key="SplashGlow">
            <DoubleAnimation Storyboard.TargetName="GlowRing"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="0.8" Duration="0:0:0.8"
                            BeginTime="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="GlowScale"
                            Storyboard.TargetProperty="ScaleX"
                            From="0.8" To="1.15" Duration="0:0:1.5"
                            BeginTime="0:0:0.3"
                            EasingFunction="{StaticResource EaseOut}"
                            RepeatBehavior="Forever" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="GlowScale"
                            Storyboard.TargetProperty="ScaleY"
                            From="0.8" To="1.15" Duration="0:0:1.5"
                            BeginTime="0:0:0.3"
                            EasingFunction="{StaticResource EaseOut}"
                            RepeatBehavior="Forever" AutoReverse="True"/>
        </Storyboard>

        <Storyboard x:Key="TextReveal">
            <DoubleAnimation Storyboard.TargetName="TitleText"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="1" Duration="0:0:0.8"
                            BeginTime="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="TitleBlur"
                            Storyboard.TargetProperty="Radius"
                            From="20" To="0" Duration="0:0:0.8"
                            BeginTime="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="SubText"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="1" Duration="0:0:0.6"
                            BeginTime="0:0:1.0"/>
        </Storyboard>

        <Storyboard x:Key="ScanLine">
            <DoubleAnimation Storyboard.TargetName="ScanLine"
                            Storyboard.TargetProperty="Y"
                            From="-20" To="460" Duration="0:0:1.8"
                            BeginTime="0:0:0.4"
                            RepeatBehavior="Forever"/>
        </Storyboard>

        <Storyboard x:Key="SplashOut">
            <DoubleAnimation Storyboard.TargetName="MainGrid"
                            Storyboard.TargetProperty="Opacity"
                            From="1" To="0" Duration="0:0:0.4"
                            BeginTime="0:0:0"/>
            <DoubleAnimation Storyboard.TargetName="ScaleMain"
                            Storyboard.TargetProperty="ScaleX"
                            From="1" To="1.1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="ScaleMain"
                            Storyboard.TargetProperty="ScaleY"
                            From="1" To="1.1" Duration="0:0:0.4"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="MainGrid" Opacity="0">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="ScaleMain" CenterX="260" CenterY="320"/>
        </Grid.RenderTransform>

        <Border Background="#0d1117" CornerRadius="12" BorderBrush="#30363d" BorderThickness="1">
            <Grid>
                <!-- Glow ring behind logo -->
                <Ellipse x:Name="GlowRing" Width="280" Height="280"
                         HorizontalAlignment="Center" VerticalAlignment="Top"
                         Margin="0,60,0,0" Opacity="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#58a6ff" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="0.7"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="GlowScale" CenterX="140" CenterY="140"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Logo image with clip -->
                <Border Width="180" Height="180"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,110,0,0" CornerRadius="12"
                        ClipToBounds="True">
                    <Grid>
                        <Image Source="Assets/logo.jpg"
                               Stretch="UniformToFill"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1"/>
                            </Image.RenderTransform>
                        </Image>
                        <!-- Scan line overlay -->
                        <Rectangle x:Name="ScanRect" Width="180" Height="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="ScanLine" Y="-20"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0.0"/>
                                    <GradientStop Color="#58a6ff" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>

                <!-- Title text -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,70">
                    <TextBlock x:Name="TitleText" Text="WRAITH"
                               Foreground="#58a6ff" FontSize="36" FontWeight="Bold"
                               FontFamily="Cascadia Code, Consolas"
                               HorizontalAlignment="Center" Opacity="0">
                        <TextBlock.Effect>
                            <BlurEffect x:Name="TitleBlur" Radius="20"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="SubText" Text="Process Surveillance  &amp;  Threat Detection"
                               Foreground="#8b949e" FontSize="12"
                               FontFamily="Cascadia Code, Consolas"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               Opacity="0"/>
                </StackPanel>

                <!-- Loading bar -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30">
                    <Border Width="220" Height="3" Background="#21262d" CornerRadius="1.5">
                        <Border x:Name="LoadBar" Width="0" Height="3" HorizontalAlignment="Left"
                                CornerRadius="1.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#58a6ff" Offset="0.0"/>
                                    <GradientStop Color="#3fb950" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="Wraith.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="780" Width="1320"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="EventListItem" TargetType="ListViewItem">
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="CardListItem" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Margin="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinBtnMin" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363d"/>
                                <Setter Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinBtnClose" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da3633"/>
                                <Setter Property="BorderBrush" Value="#f85149"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="EventItemTemplate">
            <Grid Margin="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="85"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding TimeStr}"
                           Foreground="#484f58" FontSize="11"
                           FontFamily="Cascadia Code, Consolas"/>
                <TextBlock Grid.Column="1" Text="{Binding TypeTag}"
                           Foreground="{Binding Color}" FontSize="11"
                           FontFamily="Cascadia Code, Consolas" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="{Binding PidStr}"
                           Foreground="#58a6ff" FontSize="11"
                           FontFamily="Cascadia Code, Consolas"/>
                <TextBlock Grid.Column="3" Text="{Binding Name}"
                           Foreground="#c9d1d9" FontSize="11"
                           FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="4" Text="{Binding Detail}"
                           Foreground="#8b949e" FontSize="11"
                           FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SuspiciousProcessTemplate">
            <Border Background="#161b22" CornerRadius="4" Padding="12,10"
                    Margin="0,0,0,6" BorderBrush="#30363d" BorderThickness="1"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Name}" Foreground="#f85149"
                                       FontSize="14" FontWeight="Bold"
                                       FontFamily="Cascadia Code, Consolas"/>
                            <TextBlock Text="  PID=" Foreground="#8b949e" FontSize="11"
                                       FontFamily="Cascadia Code, Consolas"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PID}" Foreground="#58a6ff" FontSize="11"
                                       FontFamily="Cascadia Code, Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Reason}" Foreground="#d29922" FontSize="11"
                                   Margin="0,0,0,4" TextWrapping="Wrap"
                                   FontFamily="Cascadia Code, Consolas"/>
                        <TextBlock Text="{Binding Path}" Foreground="#484f58" FontSize="10"
                                   Margin="0,0,0,6" TextTrimming="CharacterEllipsis"
                                   FontFamily="Cascadia Code, Consolas"/>
                        <WrapPanel Orientation="Horizontal">
                            <Border Background="#0d1117" CornerRadius="3" Padding="5,2" Margin="0,0,4,3">
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="DLL " Foreground="#484f58"/><Run Text="{Binding DllLoads}" Foreground="#7ee787"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#0d1117" CornerRadius="3" Padding="5,2" Margin="0,0,4,3">
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="REG " Foreground="#484f58"/><Run Text="{Binding RegistryWrites}" Foreground="#ffa657"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#0d1117" CornerRadius="3" Padding="5,2" Margin="0,0,4,3">
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="CLIP " Foreground="#484f58"/><Run Text="{Binding ClipboardAccess}" Foreground="#bc8cff"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#0d1117" CornerRadius="3" Padding="5,2" Margin="0,0,4,3">
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="PIPE " Foreground="#484f58"/><Run Text="{Binding PipeCount}" Foreground="#79c0ff"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#0d1117" CornerRadius="3" Padding="5,2" Margin="0,0,0,3">
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="FOCUS " Foreground="#484f58"/><Run Text="{Binding FocusEvents}" Foreground="#d29922"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#0d1117" CornerRadius="3" Padding="5,2" Margin="0,0,0,3">
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="THR " Foreground="#484f58"/><Run Text="{Binding ThreadCount}" Foreground="#f85149"/>
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="TERMINATE"
                            Style="{StaticResource BtnKill}"
                            VerticalAlignment="Center"
                            Click="KillProcess_Click"
                            Tag="{Binding PID}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AlertItemTemplate">
            <Border Background="#161b22" CornerRadius="4" Padding="10,8"
                    Margin="0,0,0,4"
                    BorderBrush="{Binding SeverityColor}"
                    BorderThickness="2,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SeverityText}"
                                       Foreground="{Binding SeverityColor}"
                                       FontSize="11" FontWeight="Bold"
                                       FontFamily="Cascadia Code, Consolas"/>
                            <TextBlock Text="  " />
                            <TextBlock Text="{Binding TimeStr}"
                                       Foreground="#484f58" FontSize="11"
                                       FontFamily="Cascadia Code, Consolas"/>
                        </StackPanel>
                        <TextBlock Margin="0,3,0,0" FontSize="11"
                                   FontFamily="Cascadia Code, Consolas">
                            <Run Text="PID=" Foreground="#8b949e"/>
                            <Run Text="{Binding PID}" Foreground="#58a6ff"/>
                            <Run Text="  " />
                            <Run Text="{Binding ProcessName}" Foreground="#c9d1d9" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Message}" Foreground="#8b949e" FontSize="11"
                                   Margin="0,2,0,0" TextWrapping="Wrap"
                                   FontFamily="Cascadia Code, Consolas"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="TERMINATE"
                                Style="{StaticResource BtnKill}"
                                Margin="0,0,4,0"
                                Click="KillAlertProcess_Click"
                                Tag="{Binding PID}"/>
                        <Button Content="DISMISS"
                                Style="{StaticResource BtnIgnore}"
                                Click="DismissAlert_Click"
                                Tag="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#0d1117" CornerRadius="8" BorderBrush="#30363d" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="#161b22" CornerRadius="8,8,0,0"
                    BorderBrush="#30363d" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Height="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- TITLE TEXT -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="Wraith"
                                   Foreground="#58a6ff"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   FontFamily="Cascadia Code, Consolas"/>
                        <TextBlock Text="MADE BY REAL"
                                   Foreground="#484f58"
                                   FontSize="9"
                                   FontFamily="Cascadia Code, Consolas"
                                   Margin="0,1,0,0"/>
                    </StackPanel>

                    <!-- WINDOW CONTROLS + STATUS -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#484f58" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" Text="IDLE" Foreground="#8b949e"
                                   FontSize="11" FontWeight="Bold"
                                   FontFamily="Cascadia Code, Consolas"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Style="{StaticResource WinBtnMin}" Click="BtnMinimize_Click">
                            <Canvas Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Line X1="5" Y1="14" X2="15" Y2="14"
                                      Stroke="#8b949e" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                        <Button Style="{StaticResource WinBtnClose}" Click="BtnClose_Click">
                            <Canvas Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Line X1="6" Y1="6" X2="14" Y2="14"
                                      Stroke="#8b949e" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="6" X2="6" Y2="14"
                                      Stroke="#8b949e" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- STATS BAR -->
            <Border Grid.Row="1" Background="#0d1117" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="16,5">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource StatLabel}" Text="Procs: " VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatProcs" Style="{StaticResource StatValue}" Text="0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource StatLabel}" Text="Alerts: " VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatAlerts" Style="{StaticResource StatValue}" Text="0" VerticalAlignment="Center"
                                   Foreground="#f85149"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource StatLabel}" Text="Events: " VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatEvents" Style="{StaticResource StatValue}" Text="0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource StatLabel}" Text="Uptime: " VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatUptime" Style="{StaticResource StatValue}" Text="00:00:00" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource StatLabel}" Text="TM: " VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatTm" Style="{StaticResource StatValue}" Text="--" VerticalAlignment="Center"
                                   Foreground="#8b949e"/>
                    </StackPanel>
                    <TextBlock x:Name="StatTmStatus" Style="{StaticResource StatLabel}" Text="" VerticalAlignment="Center"
                               Foreground="#d29922" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="2" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="420" MinWidth="280"/>
                </Grid.ColumnDefinitions>

                <!-- EVENT STREAM -->
                <Border Grid.Column="0" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="12,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="EVENT  STREAM" Foreground="#58a6ff"
                                           FontSize="12" FontWeight="Bold"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                        <ListView Grid.Row="1" x:Name="EventList"
                                  ItemTemplate="{StaticResource EventItemTemplate}"
                                  ItemContainerStyle="{StaticResource EventListItem}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent" BorderThickness="0"/>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                              Background="#0d1117" ResizeBehavior="BasedOnAlignment"/>

                <!-- RIGHT PANEL -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="150"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*" MinHeight="150"/>
                    </Grid.RowDefinitions>

                    <!-- SUSPICIOUS PROCESSES -->
                    <Border Grid.Row="0" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="12,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SUSPICIOUS  PROCESSES" Foreground="#58a6ff"
                                               FontSize="12" FontWeight="Bold"
                                               FontFamily="Cascadia Code, Consolas"/>
                                    <TextBlock x:Name="SuspiciousCount" Text="0" Foreground="#f85149"
                                               FontSize="12" FontWeight="Bold" Margin="8,0,0,0"
                                               FontFamily="Cascadia Code, Consolas"/>
                                </StackPanel>
                            </Border>
                            <ListView Grid.Row="1" x:Name="SuspiciousList"
                                      ItemTemplate="{StaticResource SuspiciousProcessTemplate}"
                                      ItemContainerStyle="{StaticResource CardListItem}"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                  Background="#0d1117" ResizeBehavior="BasedOnAlignment"/>

                    <!-- ALERTS -->
                    <Border Grid.Row="2" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="12,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ALERTS" Foreground="#58a6ff"
                                               FontSize="12" FontWeight="Bold"
                                               FontFamily="Cascadia Code, Consolas"/>
                                    <TextBlock x:Name="AlertCount" Text="0" Foreground="#f85149"
                                               FontSize="12" FontWeight="Bold" Margin="8,0,0,0"
                                               FontFamily="Cascadia Code, Consolas"/>
                                </StackPanel>
                            </Border>
                            <ListView Grid.Row="1" x:Name="AlertList"
                                      ItemTemplate="{StaticResource AlertItemTemplate}"
                                      ItemContainerStyle="{StaticResource CardListItem}"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ACTION BAR -->
            <Border Grid.Row="3" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="16,7">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnStart" Content="START MONITORING"
                            Style="{StaticResource BtnPrimary}"
                            Click="BtnStart_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnStop" Content="STOP"
                            Style="{StaticResource BtnSecondary}"
                            Click="BtnStop_Click" Margin="0,0,8,0" IsEnabled="False"/>
                    <Button x:Name="BtnExport" Content="EXPORT REPORT"
                            Style="{StaticResource BtnSecondary}"
                            Click="BtnExport_Click" Margin="0,0,8,0" IsEnabled="False"/>
                    <Button x:Name="BtnClear" Content="CLEAR LOG"
                            Style="{StaticResource BtnSecondary}"
                            Click="BtnClear_Click" Margin="0,0,8,0"/>
                </StackPanel>
            </Border>

            <!-- STATUS BAR -->
            <Border Grid.Row="4" Background="#161b22" CornerRadius="0,0,8,8"
                    BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="16,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="StatusBar" Text="Ready. Click START MONITORING to begin."
                               Foreground="#8b949e" FontSize="11"
                               FontFamily="Cascadia Code, Consolas" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="VersionText" Text="v2.1.1"
                                   Foreground="#484f58" FontSize="10"
                                   FontFamily="Cascadia Code, Consolas" VerticalAlignment="Center"/>
                        <TextBlock x:Name="UpdateStatus" Text="" Foreground="#484f58" FontSize="10"
                                   FontFamily="Cascadia Code, Consolas" VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                        <Button x:Name="BtnUpdate" Content="UPDATE" Visibility="Collapsed"
                                Style="{StaticResource BtnSecondary}" Padding="6,2" FontSize="9"
                                Margin="8,0,0,0" Click="BtnUpdate_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
